JELLYFIN_URL=http://<your-jellyfin-host>:8096
JELLYFIN_API_KEY=<your-jellyfin-api-key>

# Whisper settings
WHISPER_MODEL=base        # tiny | base | small | medium | large-v3
WHISPER_LANGUAGE=en

# Path remapping: translate Jellyfin's server-side paths to the local mount point
# e.g. Jellyfin reports /media/movies/foo.mkv, but it's mounted at /mnt/jellyfin/movies/foo.mkv
MEDIA_ROOT_REMOTE=/media
MEDIA_ROOT_LOCAL=/mnt/jellyfin
